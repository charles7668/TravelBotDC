# Discord Bot 設定
# 在此填入您的 Discord Bot Token (來源: https://discord.com/developers/applications)
DISCORD_TOKEN=YOUR_DISCORD_BOT_TOKEN_HERE

# 關聯式資料庫設定
# 在此填寫 PostgreSQL 的連線字串 (使用 asyncpg)
DATABASE_URL=postgres://你的帳號:你的密碼@127.0.0.1:5432/你的資料庫名稱

# OpenRouter 設定
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_MODEL=google/gemini-2.0-flash-lite:free
